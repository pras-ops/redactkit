{
  "name": "redactkit",
  "version": "0.1.0",
  "description": "Local PII redaction and restoration for cloud LLMs — redact before sending, restore on reply, 100% on-device",
  "type": "module",
  "main": "dist/index.js",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./node": {
      "import": "./src/node.js"
    },
    "./browser-pii-shield": {
      "import": "./dist/index.js"
    },
    "./browser-pii-shield/node": {
      "import": "./src/node.js"
    }
  },
  "bin": {
    "redactkit": "bin/redactkit.js"
  },
  "engines": {
    "node": ">=18"
  },
  "files": [
    "dist",
    "src",
    "bin",
    "README.md",
    "LICENSE"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/pras-ops/redactkit.git"
  },
  "homepage": "https://github.com/pras-ops/redactkit#readme",
  "bugs": {
    "url": "https://github.com/pras-ops/redactkit/issues"
  },
  "scripts": {
    "build": "tsup src/index.js --format esm --dts --out-dir dist",
    "prepublishOnly": "npm run build",
    "test": "vitest",
    "dev": "npx http-server . -p 8080 -c-1",
    "serve": "node bin/redactkit.js serve"
  },
  "keywords": [
    "llm",
    "webgpu",
    "privacy",
    "browser",
    "nlp",
    "preprocessing",
    "client-side",
    "webllm",
    "text-processing",
    "local-ai",
    "text-cleaning",
    "extraction",
    "privacy-first",
    "offline",
    "browser-ai",
    "data-extraction",
    "token-reduction",
    "cost-saving",
    "experimental"
  ],
  "author": "RedactKit Contributors",
  "license": "Apache-2.0",
  "dependencies": {
    "@mlc-ai/web-llm": "^0.2.80"
  },
  "optionalDependencies": {
    "@huggingface/transformers": "^3.8.1",
    "sharp": "^0.35.2",
    "tesseract.js": "^7.0.0"
  },
  "devDependencies": {
    "@esbuild-plugins/node-modules-polyfill": "^0.2.2",
    "tsup": "^8.0.1",
    "typescript": "^5.9.3",
    "vite": "^7.3.0",
    "vitest": "^1.1.0"
  }
}
